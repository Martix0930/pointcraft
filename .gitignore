# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Environments
.venv/
venv/
.env

# Outputs / artifacts
outputs/*
!outputs/.gitkeep
output/
experiments/*/outputs/
*.schem
*.litematic

# Data files (large / raw)
*.las
*.laz
*.ply
*.e57
*.obj
*.mtl
*.npz
*.npy
data/
raw/
raw_data/

# Model checkpoints & training logs
*.ckpt
*.pth
*.pt
checkpoints/
wandb/
runs/
tb_logs/
tensorboard/
lightning_logs/

# Editor / OS
.idea/
.vscode/
.DS_Store
Thumbs.db

# Keep
!experiments/README.md

# Tiny committed test fixtures (allow small files under test_data/ only).
# Real/large datasets stay ignored by the patterns above; these negations
# re-include only the tiny synthetic fixtures.
!test_data/
!test_data/**/
!test_data/**/*.obj
!test_data/**/*.csv
!test_data/**/*.json
!test_data/**/*.md
# NOTE: do NOT add !test_data/**/*.npz or *.npy unless such tiny fixtures
# are intentionally created — generated training samples must stay ignored.
